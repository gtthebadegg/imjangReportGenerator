# Copy to .env or ~/.config/imjang-report/secrets.env
# Do not commit real keys.

# Kakao Local REST API key (recommended; required for full apartment POI/geocoding collection)
# Create app: https://developers.kakao.com/console/app
# Use REST API key, not JavaScript key.
KAKAO_REST_API_KEY=

# data.go.kr service key for 국토교통부_아파트 매매 실거래가 자료 / RTMSDataSvcAptTrade
# Data page: https://www.data.go.kr/data/15126469/openapi.do
# Use Encoding key. Either variable name is accepted.
MOLIT_SERVICE_KEY=
# DATA_GO_KR_SERVICE_KEY=

# Optional: VWorld search/geocoding fallback
# Data page: https://www.data.go.kr/data/15000273/openapi.do
VWORLD_KEY=

# Optional: proxy for region-code/rent fallback. If omitted, scripts may use the public default.
KSKILL_PROXY_BASE_URL=https://k-skill-proxy.nomadamas.org
